# ClickUp Brain 凭据（抓包后回填，请勿提交真实值）
# ===== 首次使用必须配置：JWT、Workspace ID、API_KEY =====

# 方式一：单账号
CLICKUP_JWT=
CLICKUP_WORKSPACE_ID=

# 方式二：多账号，推荐显式填写 jwt|workspace_id，账号之间用逗号分隔
# CLICKUP_ACCOUNTS=eyJhbGci...jwt1|90100000001,eyJhbGci...jwt2|90100000002

# 方式三：多账号，JSON 格式（支持 label 和显式 workspace_id）
# CLICKUP_ACCOUNTS_JSON=[{"jwt":"eyJ...","workspace_id":"90100000001","label":"acc1"},{"jwt":"eyJ...","workspace_id":"90100000002","label":"acc2"}]

# Refresh JWT 暂未支持；access JWT 过期后仍需重新获取
# CLICKUP_REFRESH_JWT=
# Session token 留空，2api 自动管理；也可手动填入覆盖自动刷新
CLICKUP_TOKEN=
CLICKUP_COOKIE=
CLICKUP_EXTRA_HEADERS=

# ClickUp GraphQL 网关（一般不用改；海外区域改对应域名）
CLICKUP_BASE_URL=https://frontdoor-search.clickup-prod.com
CLICKUP_ACCESS_TOKEN_BASE=https://frontdoor-prod-us-east-2-2.clickup.com
# 新加坡区域示例：
# CLICKUP_BASE_URL=https://frontdoor-search.clickup-sg.com
# CLICKUP_ACCESS_TOKEN_BASE=https://frontdoor-prod-ap-southeast-1-1.clickup.com
CLICKUP_GRAPHQL_PATH=/graphql/gateway

# ClickUp Web 客户端标识
CLICKUP_ANONYMOUS_ID=
CLICKUP_CLIENT_VERSION=4.13.3
CLICKUP_LOCALE=en-US
CLICKUP_SURFACE=client
CLICKUP_TZ_OFFSET=-480
CLICKUP_SD_TAB_ID=
# 2api 自身访问密钥（必填，不是 ClickUp JWT）
API_KEY=

# mock 模式：不调用 ClickUp，返回假数据，用于先验证框架
CLICKUP_MOCK=0

# 服务端口
HOST=127.0.0.1
PORT=8787
